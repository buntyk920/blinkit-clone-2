{
  "name": "freshmart-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec node --loader tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node --loader tsx database/migrations/run.ts",
    "seed": "node --loader tsx database/seeds/run.ts",
    "test": "jest",
    "test:integration": "jest --testMatch='**/*.integration.test.ts'",
    "lint": "eslint src"
  },
  "dependencies": {
    "express": "^4.18.2",
    "typescript": "^5.2.2",
    "pg": "^8.11.0",
    "redis": "^4.6.10",
    "jsonwebtoken": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "socket.io": "^4.7.1",
    "axios": "^1.5.0",
    "stripe": "^13.6.0",
    "joi": "^17.10.2",
    "@tensorflow/tfjs": "^4.10.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.8.0",
    "@types/jest": "^29.5.5",
    "nodemon": "^3.0.1",
    "tsx": "^3.13.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript-eslint": "^6.7.5"
  }
}
